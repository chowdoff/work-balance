# 数据库连接
DATABASE_URL="postgresql://work-balance:work-balance@localhost:5432/work-balance"

# NextAuth 密钥（生产环境请使用 openssl rand -base64 32 生成）
NEXTAUTH_SECRET="change-this-in-production"

# 种子数据 - 管理员账号（必填）
SEED_ADMIN_EMAIL="admin@company.com"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="系统管理员"

# 种子数据 - 初始工作年度（必填）
SEED_WORK_YEAR_NAME="2026年度"
SEED_WORK_YEAR_START="2026-01-01"
SEED_WORK_YEAR_END="2026-12-31"

# 开发环境 - 允许的局域网来源（逗号分隔）
ALLOWED_DEV_ORIGINS="192.168.200.128"
